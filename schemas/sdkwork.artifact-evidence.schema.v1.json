{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/sdkwork.artifact-evidence.schema.v1.json",
  "title": "SDKWork Release Artifact Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifactId", "artifactPath", "digest", "version", "sourceCommit", "packageId", "profileBinding", "runtimeTarget", "sbom", "provenance", "signature"],
  "properties": {
    "artifactId": { "type": "string", "minLength": 1 },
    "artifactPath": { "type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "version": { "type": "string", "minLength": 1 },
    "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
    "packageId": { "type": "string", "minLength": 1 },
    "profileBinding": { "enum": ["fixed", "runtime-configurable"] },
    "profile": { "type": "string", "pattern": "^(standalone|cloud)\\.(test|staging|production)$" },
    "environment": { "enum": ["test", "staging", "production"] },
    "deploymentProfile": { "enum": ["standalone", "cloud"] },
    "supportedDeploymentProfiles": { "type": "array", "items": { "enum": ["standalone", "cloud"] }, "uniqueItems": true },
    "runtimeTarget": { "type": "string", "minLength": 1 },
    "sbom": { "type": ["string", "object"] },
    "provenance": { "type": ["string", "object"] },
    "signature": { "type": ["string", "object"] }
  },
  "oneOf": [
    {
      "required": ["deploymentProfile"],
      "properties": { "profileBinding": { "const": "fixed" } },
      "not": { "required": ["supportedDeploymentProfiles"] }
    },
    {
      "required": ["supportedDeploymentProfiles"],
      "properties": {
        "profileBinding": { "const": "runtime-configurable" },
        "supportedDeploymentProfiles": { "const": ["standalone", "cloud"] }
      },
      "not": { "required": ["deploymentProfile"] }
    }
  ]
}
