{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/sdkwork.app.topology.schema.v5.json",
  "title": "SDKWork Application Runtime Topology v5",
  "type": "object",
  "additionalProperties": true,
  "not": { "required": ["cloudIngress"] },
  "required": ["schemaVersion", "kind", "appId", "vocabulary", "profileFiles", "surfaces", "orchestration"],
  "properties": {
    "schemaVersion": { "const": 5 },
    "kind": { "const": "sdkwork.app.topology" },
    "appId": { "type": "string", "pattern": "^sdkwork-[a-z0-9-]+$" },
    "vocabulary": {
      "type": "object",
      "required": ["deploymentProfile", "environment"],
      "properties": {
        "deploymentProfile": {
          "type": "object",
          "required": ["allowed"],
          "properties": {
            "allowed": { "const": ["standalone", "cloud"] }
          }
        },
        "environment": {
          "type": "object",
          "required": ["allowed"],
          "properties": {
            "allowed": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true }
          }
        }
      }
    },
    "profileFiles": {
      "type": "object",
      "patternProperties": {
        "^(standalone|cloud)\\.[a-z0-9-]+$": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "connectivityPlane": { "enum": ["application", "platform", "dependency"] },
          "protocols": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
          "httpUrlEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "clientHttpEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "autostartEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" }
        }
      }
    },
    "orchestration": {
      "type": "object",
      "required": ["profiles"],
      "properties": {
        "profiles": {
          "type": "object",
          "patternProperties": {
            "^(standalone|cloud)\\.[a-z0-9-]+$": {
              "type": "object",
              "properties": {
                "processes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "role"],
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "role": { "enum": ["client", "api-standalone-gateway", "edge-runtime", "database", "redis", "migration", "seed", "worker", "tunnel"] },
                      "script": { "type": "string", "minLength": 1 },
                      "decisionRef": { "type": "string", "pattern": "^docs/(adr|architecture/decisions)/[A-Za-z0-9._/-]+\\.md$" },
                      "bindEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
                      "runtimeTargets": {
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": { "type": "string" }
                      },
                      "clientArchitectures": {
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": {
                          "enum": ["pc-web", "h5", "capacitor", "flutter", "tauri", "electron", "android-native", "ios-native", "harmony-native", "mini-program"]
                        }
                      }
                    },
                    "allOf": [
                      {
                        "if": { "properties": { "role": { "const": "edge-runtime" } }, "required": ["role"] },
                        "then": {
                          "required": ["script", "decisionRef"],
                          "properties": {
                            "script": { "pattern": "^_sdkwork:runtime:[a-z0-9][a-z0-9:-]*$" }
                          }
                        }
                      }
                    ]
                  }
                },
                "managedResources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "driver"],
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "driver": { "enum": ["windows-wsl-tcp-portproxy"] },
                      "enabledEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
                      "listenAddressEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
                      "listenAddress": { "type": "string", "minLength": 1 },
                      "listenPortEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
                      "listenPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
                      "distributionEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
                      "distribution": { "type": "string", "minLength": 1 }
                    }
                  }
                }
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
