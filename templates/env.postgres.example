# SDKWork unified workspace PostgreSQL profile.
# Canonical source: sdkwork-clawrouter/.env.postgres.example
# Copy to .env.postgres in any application root (or sdkwork-clawrouter) for host-local overrides.
# Do not commit .env.postgres.
#
# All SDKWork applications MUST use these SDKWORK_CLAW_DATABASE_* keys for PostgreSQL
# connection identity in development and production. Per-app SDKWORK_<APP>_DATABASE_NAME,
# USERNAME, PASSWORD, SCHEMA, and URL MUST NOT define different values in checked-in files.

SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10

# Optional: direct connection URL. If set, it takes precedence over split fields above.
# SDKWORK_CLAW_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# Required for database init when creating roles/databases with an admin connection.
SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable

# Optional: direct admin connection URL.
# SDKWORK_CLAW_DATABASE_ADMIN_URL=postgresql://postgres:postgres_admin_pass@127.0.0.1:5432/postgres?sslmode=disable
